generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model badge {
  id          Int    @id @default(autoincrement())
  name        String
  requirement String
}

model basespirit {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  details String?
  recipes recipe[]
}

model category {
  id      Int      @id @default(autoincrement())
  name    String
  details String?
  recipes recipe[]
}

model recipe {
  id           Int      @id @default(autoincrement())
  name         String
  ingredients  String   @db.Text
  instructions String   @db.Text
  image        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId       Int?
  categoryId   Int?
  baseSpiritId Int?

  // Relations - ensure these names match exactly what you use in .include()
  user       user?       @relation(fields: [userId], references: [id])
  category   category?   @relation(fields: [categoryId], references: [id])
  basespirit basespirit? @relation(fields: [baseSpiritId], references: [id])

  @@index([baseSpiritId])
  @@index([categoryId])
  @@index([userId])
}

model user {
  id             Int       @id @default(autoincrement())
  username       String    @unique
  email          String    @unique
  password       String
  role           user_role @default(USER)
  info           String?
  profilePicture String?
  createdAt      DateTime  @default(now())
  recipes        recipe[]
}

model userbadge {
  archievedAt DateTime @id @default(now())
  userId      Int?
  badgeId     Int?

  @@unique([userId, badgeId])
  @@index([badgeId])
}

enum user_role {
  USER
  ADMIN
}
